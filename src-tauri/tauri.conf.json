{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatingTodo",
  "version": "0.1.0",
  "identifier": "com.antigravity.floatingtodo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "每日待办",
        "width": 500,
        "height": 700,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": true,
        "skipTaskbar": false,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
